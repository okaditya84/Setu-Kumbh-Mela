# Base URL of the Setu backend. No trailing slash.
# Local dev:        http://127.0.0.1:8000
# Physical phone over USB (Android): http://127.0.0.1:8000  (use `adb reverse tcp:8000 tcp:8000`)
# Production (Vercel): your Render backend URL, e.g. https://setu-backend.onrender.com
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000
