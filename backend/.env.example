# ============================================================================
#  Setu backend configuration.  Copy to ".env" and fill in.
#  The app RUNS WITH ZERO KEYS (SQLite + deterministic matching). LLM and voice
#  are optional enhancements. See docs/ENV_SETUP.md for how to get each key.
# ============================================================================

# ---- App ----
APP_ENV=dev
LOG_LEVEL=INFO
# Comma-separated allowed origins for the web/mobile clients. Use your Vercel URL
# in production, e.g. https://setu-kumbh.vercel.app . "*" is fine for the demo.
CORS_ORIGINS=*

# ---- Security (CHANGE THIS in production: any random 32+ char string) ----
SECRET_KEY=change-me-to-a-long-random-string-please
ACCESS_TOKEN_TTL_MINUTES=720
PII_PURGE_AFTER_HOURS=72

# ---- Public accounts (families self-registering) ----
# Self-signup always creates a non-admin "public" account; admin/volunteer
# logins stay private. Set to false to disable public sign-up entirely.
PUBLIC_SIGNUP_ENABLED=true

# ---- Google OAuth ("Continue with Google") — OPTIONAL ----
# Create an OAuth 2.0 *Web application* client in the GCP console, add your web
# origin to "Authorized JavaScript origins", then paste the client id/secret.
# Leave blank to hide the Google button. The client id is exposed to the browser
# via GET /config; the secret never leaves the server.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Database ----
# Default: SQLite file (zero setup). For Render Postgres, paste its URL here AND
# also `pip install -r requirements-postgres.txt`.
DATABASE_URL=sqlite:///./setu.db

# ---- Seeding ----
SEED_ON_STARTUP=true
SEED_SAMPLE_CASES=true

# ---- LLM (optional). provider: openai|anthropic|gemini|openrouter|deepseek|groq|together|ollama|none
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_API_KEY=
# Only set LLM_BASE_URL for openrouter/deepseek/groq/together/ollama or a custom gateway.
LLM_BASE_URL=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# ---- Voice / STT (optional). provider: sarvam|deepgram|elevenlabs|openai|none
VOICE_PROVIDER=none
VOICE_API_KEY=
VOICE_MODEL=saaras:v3
VOICE_BASE_URL=
VOICE_DEFAULT_LANGUAGE=hi
VOICE_STORAGE=local
VOICE_STORAGE_DIR=data/voice
# Optional S3-compatible storage (Cloudflare R2 / Backblaze B2). Leave blank for local.
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_BASE_URL=

# ---- Text-to-Speech (optional). Speaks announcements in real Indian-language
# audio (browsers lack most Indian voices). provider: sarvam|elevenlabs|none|""(auto)
# Leave blank to auto-reuse the Sarvam VOICE_* credentials above.
TTS_PROVIDER=
TTS_API_KEY=
TTS_MODEL=
TTS_SPEAKER=

# ---- Face matching (optional). provider: none | http
# When http, photos are embedded via FACE_API_URL and face similarity
# becomes a dominant matching signal. none = photos for human recognition
# only (keeps the deploy light). See docs/ENV_SETUP.md.
FACE_PROVIDER=none
FACE_API_URL=
FACE_API_KEY=
FACE_MODEL=

# ---- Maps (optional). Leave MAP_STYLE_URL blank to use free OpenStreetMap tiles.
MAP_STYLE_URL=
MAP_DEFAULT_LAT=19.9975
MAP_DEFAULT_LNG=73.7898
MAP_DEFAULT_ZOOM=12
